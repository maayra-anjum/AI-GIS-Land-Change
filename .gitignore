# ── Secrets — NEVER commit these ──────────────────────────
backend/.env
backend/service-account.json

# ── Model weights (large binary files) ─────────────────────
backend/model/weights/*.pth

# ── Runtime cache ───────────────────────────────────────────
backend/cache/

