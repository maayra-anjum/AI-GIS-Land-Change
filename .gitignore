__pycache__/
*.py[cod]
*.pyo
*.pyd
.eggs/
*.egg-info/

# ── Virtual environments ────────────────────────────────────
.venv/
venv/
env/

# ── Node ────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local

# ── OS ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.suo
*.sln
